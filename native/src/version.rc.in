// Version resource template - processed by CMake configure_file()
// Placeholders: @PROJECT_VERSION_MAJOR@, @PROJECT_VERSION_MINOR@, @PROJECT_VERSION_PATCH@, @VERSION_STRING@

#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_DLL
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Wavenumber"
            VALUE "FileDescription",  "OdbcMonkey Native ODBC Driver"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "odbc-monkey"
            VALUE "LegalCopyright",   "Wavenumber"
            VALUE "OriginalFilename", "odbc-monkey_@VERSION_STRING@.dll"
            VALUE "ProductName",      "OdbcMonkey"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
